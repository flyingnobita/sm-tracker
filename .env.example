# sm-tracker environment template
# Copy to .env and fill in values. Run `sm-tracker config` for guided setup.

# Twitter/X
# NOTE: The Twitter/X API requires a paid Basic tier subscription or higher.
# TWITTER_CONSUMER_KEY=
# TWITTER_CONSUMER_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_TOKEN_SECRET=
# TWITTER_HANDLE=

# Bluesky
# BLUESKY_HANDLE=
# BLUESKY_APP_PASSWORD=

# Farcaster (Warpcast API)
# Setup: https://warpcast.com/developer -> login -> create API app -> copy key
# FARCASTER_API_KEY=
# FARCASTER_USERNAME=

# Mastodon
# MASTODON_ACCESS_TOKEN=
# MASTODON_INSTANCE=

# Threads (Meta OAuth, MANAGE_INSIGHTS scope)
# THREADS_APP_ID=
# THREADS_APP_SECRET=
# THREADS_REDIRECT_URI=https://localhost/callback
# THREADS_ACCESS_TOKEN=
# THREADS_USER_ID=
# THREADS_ACCESS_TOKEN_EXPIRES_AT_UTC=

# Meta (Facebook & Instagram)
# The Graph API uses a token hierarchy. You need a Developer App to generate these.
# See docs/CREDENTIAL_SETUP_GUIDE.md for detailed setup instructions.
#
# Run `sm-tracker auth --platform facebook` or `sm-tracker auth --platform instagram` 
# to easily exchange your short-lived tokens for long-lived ones.
# META_APP_ID=
# META_APP_SECRET=
# META_USER_TOKEN_SHORT_LIVED=

# Facebook
# The auth command will automatically fetch and save this for you.
# FACEBOOK_PAGE_ACCESS_TOKEN=
# (Optional) If you don't have a Page Token, you can provide a User Token and target ID instead.
# FACEBOOK_ACCESS_TOKEN=
# FACEBOOK_ID=

# Instagram (Graph API)
# The auth command will automatically exchange your short token and save the long-lived one here.
# IMPORTANT: The Instagram account must be linked to the Facebook Page via Meta Business Suite.
# LONG_LIVED_USER_TOKEN=
# INSTAGRAM_ACCOUNT_ID=
# INSTAGRAM_USERNAME= # Optional: Use to track a competitor account (requires business_discovery permission)

# YouTube
# API key must have YouTube Data API v3 enabled
# YOUTUBE_API_KEY=
# Provide either a channel handle (e.g., @Google) OR a channel ID (e.g., UCK8sQmJBp8GCxrOtXWBpyEA)
# If both are provided, YOUTUBE_CHANNEL_ID takes precedence.
# YOUTUBE_HANDLE=
# YOUTUBE_CHANNEL_ID=
