# sm-tracker environment template
# Copy to .env and fill in values. Run `sm-tracker config` for guided setup.

# Twitter/X
# TWITTER_BEARER_TOKEN=
# TWITTER_HANDLE=

# Bluesky
# BLUESKY_HANDLE=
# BLUESKY_APP_PASSWORD=

# Farcaster (Warpcast API)
# Setup: https://warpcast.com/developer -> login -> create API app -> copy key
# FARCASTER_API_KEY=
# FARCASTER_USERNAME=

# Mastodon
# MASTODON_ACCESS_TOKEN=
# MASTODON_INSTANCE=

# Threads (Meta OAuth, MANAGE_INSIGHTS scope)
# THREADS_APP_ID=
# THREADS_APP_SECRET=
# THREADS_REDIRECT_URI=https://localhost/callback
# THREADS_ACCESS_TOKEN=
# THREADS_USER_ID=
# THREADS_ACCESS_TOKEN_EXPIRES_AT_UTC=

# Facebook
# You can provide FACEBOOK_PAGE_ACCESS_TOKEN directly (FACEBOOK_ID is optional and auto-detected).
# OR you can provide FACEBOOK_ACCESS_TOKEN (User Token) AND FACEBOOK_ID to automatically fetch the Page Token.
# FACEBOOK_PAGE_ACCESS_TOKEN=
# FACEBOOK_ACCESS_TOKEN=
# FACEBOOK_ID=

# Instagram (Graph API)
# Setup: Requires Facebook Developer App and Instagram Professional Account.
# IMPORTANT: The Instagram account must be linked to the Facebook Page via Meta Business Suite (Settings -> Accounts), not just the normal Facebook Page settings.
# INSTAGRAM_ACCOUNT_ID=
# INSTAGRAM_ACCESS_TOKEN=
# INSTAGRAM_USERNAME= # Optional: Use to track a competitor account (requires business_discovery permission)

# YouTube
# API key must have YouTube Data API v3 enabled
# YOUTUBE_API_KEY=
# Provide either a channel handle (e.g., @Google) OR a channel ID (e.g., UCK8sQmJBp8GCxrOtXWBpyEA)
# If both are provided, YOUTUBE_CHANNEL_ID takes precedence.
# YOUTUBE_HANDLE=
# YOUTUBE_CHANNEL_ID=
