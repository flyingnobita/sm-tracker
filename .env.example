# sm-tracker environment template
# Copy to .env and fill in values. Run `sm-tracker config` for guided setup.

# Twitter/X
# TWITTER_BEARER_TOKEN=
# TWITTER_HANDLE=

# Bluesky
# BLUESKY_HANDLE=
# BLUESKY_APP_PASSWORD=

# Farcaster (Warpcast API)
# FARCASTER_API_KEY=
# FARCASTER_USERNAME=

# Mastodon
# MASTODON_ACCESS_TOKEN=
# MASTODON_INSTANCE=

# Threads (Meta OAuth, MANAGE_INSIGHTS scope)
# THREADS_ACCESS_TOKEN=
# THREADS_USER_ID=
